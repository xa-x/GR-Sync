{
  "expo": {
    "name": "GR Sync",
    "slug": "gr-sync",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "grsync",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "GR Sync needs access to save imported photos to your library.",
        "NSBluetoothAlwaysUsageDescription": "GR Sync uses Bluetooth to connect to your Ricoh GR camera.",
        "NSLocalNetworkUsageDescription": "GR Sync needs access to the local network to connect to your Ricoh GR camera."
      },
      "entitlements": {
        "com.apple.developer.networking.wifi-info": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_STATE"
      ]
    },
    "plugins": [
      "expo-image",
      "expo-video",
      [
        "expo-media-library",
        {
          "photosPermission": "GR Sync needs access to save imported photos to your library.",
          "savePhotosPermission": "GR Sync needs access to save imported photos to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "react-native-wifi-reborn",
        {
          "fineLocationPermission": true
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "GR Sync needs location access to scan for WiFi networks."
        }
      ],
      "expo-router"
    ]
  }
}
